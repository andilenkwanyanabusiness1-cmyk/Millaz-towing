{
    "version": 2,
    "builds": [
        {
            "src": "**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/about-us",
            "dest": "/about-us.html"
        },
        {
            "src": "/authority-hub/?",
            "dest": "/authority-hub/index.html"
        }
    ]
}